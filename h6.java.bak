class h6 
{
	public static boolean perfect(int num){
		int sum=0;
		if (num<=1)
		{
			return false;
		}
		for (int i=1; i<=num/2 ; i++ )
		{
			if (num%i==0)
			{
				 sum+=i;
			}
		}
		
		if (num==sum)
		{
			return true;
		}
		else
			return false;
		
	}
	public static void main(String[] args) 
	{
		int num=28;
		if (perfect(num))
		{
			System.out.println("perfect no");
		}
		else
			System.out.println("not perfect no");


	}
}
