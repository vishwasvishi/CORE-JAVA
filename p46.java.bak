class p46 
{
	public static boolean isprime(int num){
	if(num<=1)
		return false;

	for (int i = 2; i<=num/2 ;i++ )
	{
		if(num%i==0)
			return false;
	}
	return true;

	}
	public static void main(String[] args) 
	{
		int num=11;
		if(isprime(num))
			System.out.println("is a prime no");
		else
			System.out.println("is not a prime no");
		

		

	}
}
