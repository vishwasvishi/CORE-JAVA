class p19 
{
	public static void main(String[] args) 
	{
		int num = 233;
		int product = 1, sum=0, i=0;
		while (num != 0)
		{
			sum = sum + num % 10; // sum of all number
			product = product * (num % 10); // product of all number
			num/=10;
			i++; // digit count of the number
		}
		System.out.println("product of all number"+product);
		System.out.println("sum of all number "+sum);
		System.out.print("digit count of the number"+i);

	}
}
