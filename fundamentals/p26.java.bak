class  p26
{
	public static void main(String[] args) 
	{
		int row = 5, col = 5;
		int i= 1;
		while (i<=row)
		{
			int j= 1;
			while (j<=col)
			{
				System.out.print("*");
				j++;
			}
			System.out.println("");
			i++;
		}
				int y= 1;
		while (y<=row)
		{
			int x= 1;
			while (j<=y)
			{
				System.out.print("*");
				x++;
			}
			System.out.println("");
			y++;
		}
	}
}
