class  m2 
{
	static int a=0;
	static int esum=0;
	static int osum=0;

	public static void main(String[] args) 
	{

		++a;
		if (a<=10)
		{
			 if (a%2==0)
			{
				esum+=a;
				main(null);
			}
			else  
			{
				osum+=a;
								main(null);

			}
		}


		
	}
	System.out.println("esum"+ m2.esum);
		System.out.println("osum"+m2.osum);
}
