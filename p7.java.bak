class  p7
{
	public static void main(String[] args) 
	{
int a= 101;
int b= 140;
int c= 110;
int res = a > b ? 
			(b > c ? b : (a > c ? a : c)) : 
			(a > c ? a : (b > c ? c : b));
			System.out.println(res);
	}

		public static void test1(String[] args) 
	{
		int x= 30;
		int y= 10;
		int z= 11;
		int d = x > y ? x : y;
		int finals= d > z ? d : z;
			System.out.println(finals);
	}
}
